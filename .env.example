# Environment Variables — ADF Automation Scripts
# ===============================================
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your real values in .env
#   3. NEVER commit .env to Git — it is in .gitignore

AZURE_SUBSCRIPTION_ID=your-subscription-id-here
AZURE_RESOURCE_GROUP=your-resource-group-here
ADF_FACTORY_NAME=your-adf-factory-name-here

LEGACY_SUBSCRIPTION_ID=your-legacy-subscription-id-here
LEGACY_RESOURCE_GROUP=your-legacy-resource-group-here
LEGACY_FACTORY_NAME=your-legacy-adf-factory-name-here

MIGRATED_SUBSCRIPTION_ID=your-migrated-subscription-id-here
MIGRATED_RESOURCE_GROUP=your-migrated-resource-group-here
MIGRATED_FACTORY_NAME=your-migrated-adf-factory-name-here

AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
TARGET_TIMEZONE=Australia/Sydney
